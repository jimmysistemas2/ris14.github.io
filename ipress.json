:root{--blue:#005b8f;--cyan:#009fb5;--dark:#05345c;--bg:#f3f8fb;--card:#fff;--text:#10243f;--muted:#5d7188;--shadow:0 10px 28px rgba(2,35,62,.10)}
*{box-sizing:border-box}body{margin:0;font-family:Segoe UI,Arial,sans-serif;background:var(--bg);color:var(--text);display:flex}.sidebar{width:290px;background:white;min-height:100vh;box-shadow:var(--shadow);position:fixed;left:0;top:0;z-index:5;overflow:auto}.brand-box{display:flex;height:120px;border-bottom:1px solid #e3edf4}.brand{flex:1;display:flex;align-items:center;justify-content:center;flex-direction:column;font-weight:900;color:var(--blue);font-size:2rem}.brand span{font-size:.9rem;background:#0aa1a6;color:white;border-radius:4px;padding:2px 6px}.brand.ris{color:#006b67}.brand.ris span{font-size:2rem;background:transparent;color:#004b76}.menu{padding:18px}.menu p{font-size:.8rem;font-weight:800;color:#0a3760;margin:20px 6px 8px}.menu a{display:block;padding:12px 14px;margin:4px 0;border-radius:10px;text-decoration:none;color:#12314f;cursor:pointer}.menu a:hover,.menu a.active{background:#e4f4f7;color:#006b86;font-weight:700}.main{margin-left:290px;width:calc(100% - 290px)}.topbar{height:120px;background:linear-gradient(135deg,var(--blue),#0089a7);color:white;display:flex;align-items:center;justify-content:space-between;padding:0 36px;box-shadow:var(--shadow)}.topbar h1{margin:0;text-align:center;font-size:2.1rem}.topbar span{font-size:1.15rem}.hamburger{display:none;background:transparent;border:0;color:white;font-size:2rem}.date-card{background:rgba(255,255,255,.14);padding:16px 22px;border-radius:12px;display:flex;gap:10px;flex-direction:column;align-items:center}.page{display:none;padding:28px}.active-page{display:block}.card{background:var(--card);border-radius:16px;box-shadow:var(--shadow);border:1px solid #e8eef4}.hero{display:grid;grid-template-columns:1.1fr .9fr;gap:28px;padding:34px}.hero h2{font-size:2.6rem;margin:0;color:#073f72}.hero h3{font-size:1.4rem;margin:10px 0;color:#00909a}.hero p{font-size:1.02rem;line-height:1.55}.kpi-row{display:grid;grid-template-columns:repeat(4,1fr);gap:16px;margin-top:28px;border-top:3px solid #0aa1a6;padding-top:24px}.kpi{border-radius:14px;padding:18px;text-align:center}.kpi strong{display:block;font-size:1.45rem}.kpi span{font-size:.88rem}.blue{background:#e6f4fb;color:#0875ad}.green{background:#e8f8ed;color:#08823d}.gold{background:#fff4d8;color:#b07000}.purple{background:#f2ecfb;color:#5c368c}.territory-panel{background:linear-gradient(160deg,#f7fbff,#eaf8fa);border-radius:18px;padding:22px}.territory-panel h3{margin:0 0 8px;color:#07436f}.ipress-list{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-top:14px}.ipress-item{background:white;border-left:5px solid var(--cyan);padding:10px;border-radius:10px;font-weight:650;font-size:.9rem}.module-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:20px;margin-top:22px}.module-card{padding:24px;text-align:center;transition:.2s;cursor:pointer}.module-card:hover{transform:translateY(-5px)}.icon{font-size:2.4rem;background:#e5f7fa;width:72px;height:72px;display:flex;align-items:center;justify-content:center;border-radius:50%;margin:auto}.module-card h3{color:#075073;margin-bottom:8px}.module-card p{color:#38536b;min-height:54px}.primary,.secondary{border:0;border-radius:10px;padding:12px 18px;font-weight:800;cursor:pointer}.primary{background:linear-gradient(135deg,#009fb5,#007b92);color:white}.secondary{background:#e8f4f8;color:#075073}.module-header{padding:26px;display:flex;justify-content:space-between;align-items:center}.module-header h2{margin:0;color:#073f72}.tools{display:flex;gap:12px;margin:18px 0;padding:18px}.tools input,.tools select{padding:12px;border:1px solid #cddce5;border-radius:10px;flex:1}.summary-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:18px}.mini{padding:20px}.mini span{display:block;color:var(--muted);font-size:.9rem}.mini strong{display:block;margin-top:8px}.ok{color:#12833d}.warning{color:#b07000}.powerbi-box{margin-top:20px;padding:18px}.powerbi-head{display:flex;justify-content:space-between;gap:18px;align-items:center}.powerbi-box iframe{width:100%;height:650px;border:1px dashed #b7cbd8;border-radius:12px;background:#f8fbfd}.footer{margin-top:18px;padding:18px;display:flex;justify-content:space-between;align-items:center;color:#073f72}
@media(max-width:1100px){.module-grid{grid-template-columns:repeat(2,1fr)}.hero{grid-template-columns:1fr}.kpi-row,.summary-grid{grid-template-columns:repeat(2,1fr)}}
@media(max-width:760px){body{display:block}.sidebar{transform:translateX(-100%);transition:.25s}.sidebar.open{transform:translateX(0)}.main{margin-left:0;width:100%}.topbar{height:auto;padding:18px;gap:12px}.hamburger{display:block}.date-card{display:none}.page{padding:16px}.module-grid,.kpi-row,.summary-grid,.ipress-list{grid-template-columns:1fr}.hero h2{font-size:2rem}.tools,.module-header,.footer,.powerbi-head{flex-direction:column;align-items:stretch}}
